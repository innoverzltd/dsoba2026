---
config:
  theme: base
  flowchart:
    curve: basis
---
flowchart TD
  %% Youth To Trial Conversion
  subgraph L0["Scheduler"]
    start(["Daily lifecycle check"])
  end
  subgraph L1["Membership System"]
    dob{"Valid date of birth?"}
    age{"Active Youth and age >= 18?"}
    noChange[/"Status: no change"/]
    convert["Convert Youth to Trial"]
    audit["Write lifecycle audit log"]
  end
  subgraph L2["Membership Admin"]
    exception[/"Status: manual DOB completion"/]
  end
  subgraph L3["Member"]
    notify["Send status-change notification"]
    trial[/"Status: Active Trial Member"/]
  end
  start --> dob
  dob -- "No" --> exception
  dob -- "Yes" --> age
  age -- "No" --> noChange
  age -- "Yes" --> convert
  convert --> audit
  audit --> notify
  notify --> trial
  classDef start fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef process fill:#FFE8A6,stroke:#D6AE3E,color:#172033;
  classDef decision fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef status fill:#D9C2F5,stroke:#9C6FD2,color:#172033;
  class start start;
  class dob decision;
  class exception status;
  class age decision;
  class noChange status;
  class convert process;
  class audit process;
  class notify process;
  class trial status;
