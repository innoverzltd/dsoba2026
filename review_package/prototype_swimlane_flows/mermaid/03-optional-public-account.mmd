---
config:
  theme: base
  flowchart:
    curve: basis
---
flowchart TD
  %% Optional Public Account
  subgraph L0["Public Visitor"]
    start(["Start"])
    choice{"Create / login account?"}
    login["Login with email / mobile"]
    signup["Enter basic profile"]
  end
  subgraph L1["Public Site"]
    guest[/"Status: continue as guest"/]
    history["Show profile and event history"]
  end
  subgraph L2["Account System"]
    existing{"Existing public account?"}
    verify["Send verification code"]
    verified{"Verification successful?"}
    pending[/"Status: verification pending"/]
    active[/"Status: active public account"/]
    publicOnly[/"Status: remains public account"/]
  end
  subgraph L3["Membership Path"]
    upgrade{"Apply for alumni membership?"}
    applicant[/"Status: alumni applicant"/]
  end
  start --> choice
  choice -- "No" --> guest
  choice -- "Yes" --> existing
  existing -- "Yes" --> login
  existing -- "No" --> signup
  signup --> verify
  verify --> verified
  verified -- "No" --> pending
  pending --> verify
  verified -- "Yes" --> active
  login --> active
  active --> history
  history --> upgrade
  upgrade -- "No" --> publicOnly
  upgrade -- "Yes" --> applicant
  classDef start fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef process fill:#FFE8A6,stroke:#D6AE3E,color:#172033;
  classDef decision fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef status fill:#D9C2F5,stroke:#9C6FD2,color:#172033;
  class start start;
  class choice decision;
  class guest status;
  class existing decision;
  class login process;
  class signup process;
  class verify process;
  class verified decision;
  class pending status;
  class active status;
  class history process;
  class upgrade decision;
  class publicOnly status;
  class applicant status;
