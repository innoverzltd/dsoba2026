---
config:
  theme: base
  flowchart:
    curve: basis
---
flowchart TD
  %% Annual Dinner Registration
  subgraph L0["Member"]
    start(["Start"])
    openPage["Open Annual Dinner page"]
    choose{"Individual ticket or table?"}
    details["Enter attendee / representative details"]
  end
  subgraph L1["Event Page"]
    open{"Registration open?"}
    closed[/"Status: registration closed"/]
  end
  subgraph L2["Event System"]
    individual[/"Status: draft individual ticket"/]
    table[/"Status: draft table booking"/]
    capacity{"Capacity available?"}
    waitlist[/"Status: waitlisted"/]
    confirmed[/"Status: confirmed, seat pending"/]
  end
  subgraph L3["Payment"]
    payment{"Payment completed?"}
    pending[/"Status: pending payment"/]
  end
  subgraph L4["Event Staff"]
    assign["Assign seats/tables after close"]
    assigned[/"Status: seat/table assigned"/]
  end
  start --> openPage
  openPage --> open
  open -- "No" --> closed
  open -- "Yes" --> choose
  choose -- "Individual" --> individual
  choose -- "Table" --> table
  individual --> capacity
  table --> capacity
  capacity -- "No" --> waitlist
  capacity -- "Yes" --> details
  details --> payment
  payment -- "No" --> pending
  pending --> payment
  payment -- "Yes" --> confirmed
  confirmed --> assign
  assign --> assigned
  classDef start fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef process fill:#FFE8A6,stroke:#D6AE3E,color:#172033;
  classDef decision fill:#B9E1FA,stroke:#6BAED6,color:#172033;
  classDef status fill:#D9C2F5,stroke:#9C6FD2,color:#172033;
  class start start;
  class openPage process;
  class open decision;
  class closed status;
  class choose decision;
  class individual status;
  class table status;
  class capacity decision;
  class waitlist status;
  class details process;
  class payment decision;
  class pending status;
  class confirmed status;
  class assign process;
  class assigned status;
